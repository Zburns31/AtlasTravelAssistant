# Atlas Travel Assistant — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ------------------------------------------------------------------
# LLM — powered by LiteLLM (https://docs.litellm.ai/docs/providers)
# ------------------------------------------------------------------
# Set the API key for your chosen provider.  LiteLLM auto-detects
# the correct key based on the model prefix.  Uncomment the one(s)
# you need:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=...

# Model string in LiteLLM format: <provider>/<model-name>
#   openai/gpt-4o | anthropic/claude-3-5-sonnet | groq/llama-3.3-70b-versatile
ATLAS_LLM_MODEL=openai/gpt-4o

# Default sampling temperature (0.0–2.0)
ATLAS_LLM_TEMPERATURE=0.7

# ------------------------------------------------------------------
# Langfuse — LLM observability (https://langfuse.com)
# ------------------------------------------------------------------
# When both keys are set, all LLM calls are automatically traced.
# Sign up at https://cloud.langfuse.com or self-host.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ------------------------------------------------------------------
# External services
# ------------------------------------------------------------------
# Serper.dev — Google Search / Places (https://serper.dev)
# 2,500 free queries at sign-up, no credit card required.
# SERPER_API_KEY=

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
ATLAS_DEBUG=false
ATLAS_HOST=127.0.0.1
ATLAS_PORT=8050
