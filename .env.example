# Atlas Travel Assistant — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ------------------------------------------------------------------
# LLM Model  (LiteLLM routes to the right provider automatically)
# ------------------------------------------------------------------
# The model string prefix selects the provider.  Just set the model
# and the matching API key below — no other config needed.
#
#   openrouter/google/gemini-3-flash-preview  →  OPENROUTER_API_KEY
#   groq/llama-3.3-70b-versatile              →  GROQ_API_KEY
#   gemini/gemini-2.5-flash                   →  GEMINI_API_KEY
#   openai/gpt-4o                             →  OPENAI_API_KEY
#   anthropic/claude-3-5-sonnet               →  ANTHROPIC_API_KEY

ATLAS_LLM_MODEL="gemini/gemini-3-flash-preview"

OPENROUTER_API_KEY="<your-openrouter-api-key-here>"
GROQ_API_KEY="<your-groq-api-key-here>"
GEMINI_API_KEY="<your-gemini-api-key-here>"

# ------------------------------------------------------------------
# External services
# ------------------------------------------------------------------
SERPER_API_KEY="<your-serper-key-here>"

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
ATLAS_DEBUG=false
ATLAS_HOST=127.0.0.1
ATLAS_PORT=8050
